# Copy to `.env` (in this directory or any parent — auto-loaded at startup)
# and fill in the values you actually use. Explicit shell exports always win
# over .env, so you can override any single value per-invocation.
#
# Tip: `truthmarket dev up` writes the foundry/anvil values for you.

# ----- chain -----
# foundry | baseSepolia | sepolia
TM_CHAIN=foundry
TM_RPC_URL=http://127.0.0.1:8545
TM_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# ----- wallet -----
# Anvil deterministic deployer key — replace for any non-local network.
# DO NOT commit a real key. Use the encrypted keystore instead:
#   truthmarket wallet init
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Set if you want non-interactive runs against an encrypted keystore.
# TM_KEYSTORE_PASSPHRASE=

# Vault is the per-market (vote, nonce, stake) blob; needed for reveal.
# TM_VAULT_PASSPHRASE=

# ----- paths -----
# Override `~/.truthmarket` if you want config/keystore/vault elsewhere.
# TM_HOME=
# TM_POLICY_FILE=

# --- Local anvil dev (default account #0; never use this key on mainnet) ---
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- RPC endpoints ---
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# --- Block explorer keys (verification) ---
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=

# --- ExampleToken deployment params (optional, has defaults) ---
TOKEN_NAME=Example
TOKEN_SYMBOL=EXM
TOKEN_INITIAL_SUPPLY=1000000000000000000000000
TOKEN_MAX_SUPPLY=10000000000000000000000000
# TOKEN_OWNER=0x...        # defaults to PRIVATE_KEY's address

# --- TruthMarket deployment params ---
STAKE_TOKEN=0x0000000000000000000000000000000000000000
# TREASURY=0x...           # defaults to PRIVATE_KEY's address
# ADMIN=0x...              # defaults to PRIVATE_KEY's address
# JURY_COMMITTER=0x...     # defaults to PRIVATE_KEY's address

# Claim/rules document reference (bytes hex). Example below is "ipfs://Qm..." encoded.
IPFS_HASH=0x697066733a2f2f516d4578616d706c65436c61696d
VOTING_PERIOD=86400        # seconds; 1 day
ADMIN_TIMEOUT=43200        # seconds; 12 hours window for jury committer
REVEAL_PERIOD=86400        # seconds; 1 day
PROTOCOL_FEE_BPS=500       # 5% of slashed pool to treasury
MIN_STAKE=1000000000000000000   # 1e18 wei (1 token at 18 decimals)
JURY_SIZE=3                # must be odd, <= 100
MIN_COMMITS=3              # must be >= JURY_SIZE
MIN_REVEALED_JURORS=2      # must be <= JURY_SIZE

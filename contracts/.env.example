# --- Local anvil dev (default account #0; never use this key on any public network) ---
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- RPC endpoints ---
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# --- Block explorer keys (verification) ---
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=

# --- Registry + per-clone market params ---
# Optional: deploy the predictable reference first:
#   make predict-reference
#   make deploy-reference NETWORK=sepolia
# Then paste its address here before deploying MarketRegistry. If left blank,
# MarketRegistry.s.sol uses or deploys the same deterministic CREATE2 reference.
TRUTHMARKET_REFERENCE_ADDRESS=0x09Dc04e5596e5Da506e4a6722e42523fBa4dBE16

# Deploy registry with:
#   make deploy-registry NETWORK=sepolia
# Then set REGISTRY_ADDRESS before creating a market clone.
REGISTRY_ADDRESS=0xa50B3e0Ca53f28Fb8BD0a3e0DdbFbE7fE36047E5

# Per-clone values passed to MarketRegistry.createMarket.
STAKE_TOKEN=0x543dDb01Ba47acB11de34891cD86B675F04840db
JURY_COMMITTER=0x574F91bd4d8e83F84B62c3Ca75d24684813237Cc

# Immutable Swarm/Bee claim document reference (bytes hex).
# Example below encodes "bzz://8f2b...5678" as bytes. The title/context/tags live
# in Swarm KV; the clone stores only this reference.
SWARM_REFERENCE=0x627a7a3a2f2f3866326231633364346535663637383930313233343536373839303132333435363738393031323334353637383930313233343536373839303132333435363738
VOTING_PERIOD=86400        # seconds; 1 day
ADMIN_TIMEOUT=43200        # seconds; 12 hours window for jury committer
REVEAL_PERIOD=86400        # seconds; 1 day
MIN_STAKE=1000000000000000000   # 1e18 wei (1 token at 18 decimals)
MAX_COMMITS=0              # optional hard cap; 0 = uncapped
CREATOR_BOND=0             # optional creator-funded subsidy; 0 = disabled
# Target jury bounds — MAX_TARGET_JURY_SIZE_PERCENT = 15 in source, so MIN_COMMITS * 15 >= TARGET_JURY_SIZE * 100.
# Examples: targetJurySize=1 → minCommits>=7; targetJurySize=3 → minCommits>=20; targetJurySize=5 → minCommits>=34.
TARGET_JURY_SIZE=1                # must be odd, <= 100
MIN_COMMITS=7              # must satisfy MIN_COMMITS * 15 >= TARGET_JURY_SIZE * 100
MIN_REVEALED_JURORS=1      # must be >= 1 and <= TARGET_JURY_SIZE

#!/usr/bin/env bash
# Read or write the deployed Counter contract.
#
# Usage:
#   bin/counter read              [network]
#   bin/counter inc               [network]
#   bin/counter inc-by <amount>   [network]
#   bin/counter set <number>      [network]
#
# Resolves the address from broadcast/Counter.s.sol/<chainid>/run-latest.json
# unless COUNTER_ADDRESS is set in env or .env.

set -euo pipefail
cd "$(dirname "$0")/.."

[ -f .env ] && set -a && source .env && set +a

cmd="${1:-}"
shift || true

# allow chainid override via $2 for set/inc-by, otherwise default to anvil
case "$cmd" in
  read|inc) arg=""; network="${1:-anvil}" ;;
  inc-by|set) arg="${1:-}"; network="${2:-anvil}" ;;
  -h|--help|"") sed -n '2,11p' "$0"; exit 0 ;;
  *) echo "unknown subcommand: $cmd" >&2; exit 1 ;;
esac

# pick chain id for broadcast lookup
case "$network" in
  anvil) chainid=31337 ;;
  sepolia) chainid=11155111 ;;
  mainnet) chainid=1 ;;
  base) chainid=8453 ;;
  base_sepolia) chainid=84532 ;;
  *) chainid="$network" ;; # allow raw chain id
esac

addr="${COUNTER_ADDRESS:-}"
if [ -z "$addr" ]; then
  artifact="broadcast/Counter.s.sol/${chainid}/run-latest.json"
  [ -f "$artifact" ] || { echo "no deployment found at $artifact (run 'bin/deploy counter $network' first, or export COUNTER_ADDRESS)"; exit 1; }
  addr=$(jq -r '.transactions[0].contractAddress' "$artifact")
fi

case "$cmd" in
  read)
    cast call "$addr" "number()(uint256)" --rpc-url "$network"
    ;;
  inc)
    : "${PRIVATE_KEY:?PRIVATE_KEY must be set}"
    cast send "$addr" "increment()" --rpc-url "$network" --private-key "$PRIVATE_KEY" >/dev/null
    cast call "$addr" "number()(uint256)" --rpc-url "$network"
    ;;
  inc-by)
    : "${arg:?usage: bin/counter inc-by <amount>}"
    : "${PRIVATE_KEY:?PRIVATE_KEY must be set}"
    cast send "$addr" "incrementBy(uint256)" "$arg" --rpc-url "$network" --private-key "$PRIVATE_KEY" >/dev/null
    cast call "$addr" "number()(uint256)" --rpc-url "$network"
    ;;
  set)
    : "${arg:?usage: bin/counter set <number>}"
    : "${PRIVATE_KEY:?PRIVATE_KEY must be set}"
    cast send "$addr" "setNumber(uint256)" "$arg" --rpc-url "$network" --private-key "$PRIVATE_KEY" >/dev/null
    cast call "$addr" "number()(uint256)" --rpc-url "$network"
    ;;
esac

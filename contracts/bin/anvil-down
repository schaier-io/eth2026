#!/usr/bin/env bash
# Stop the anvil started by bin/anvil-up.
set -euo pipefail
cd "$(dirname "$0")/.."

PIDFILE=.anvil.pid
if [ ! -f "$PIDFILE" ]; then
  echo "no $PIDFILE; nothing to stop"
  exit 0
fi

pid=$(cat "$PIDFILE")
if kill -0 "$pid" 2>/dev/null; then
  kill "$pid"
  echo "stopped anvil (pid $pid)"
else
  echo "anvil pid $pid not running"
fi
rm -f "$PIDFILE"

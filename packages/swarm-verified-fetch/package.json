{
  "name": "@truth-market/swarm-verified-fetch",
  "version": "0.1.0-alpha.0",
  "description": "Fetch-shaped Swarm gateway reads with client-side verification.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "sideEffects": false,
  "license": "MIT",
  "author": "TruthMarket",
  "homepage": "https://github.com/schaier-io/eth2026/tree/main/packages/swarm-verified-fetch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schaier-io/eth2026.git",
    "directory": "packages/swarm-verified-fetch"
  },
  "bugs": {
    "url": "https://github.com/schaier-io/eth2026/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "node": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "browser": "./dist/index.js",
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e*.test.ts",
    "check": "pnpm typecheck && pnpm test",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "keywords": [
    "swarm",
    "bee",
    "verified-fetch",
    "gateway",
    "bmt",
    "cac",
    "soc",
    "feeds"
  ],
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0"
  },
  "devDependencies": {
    "@types/node": ">=20.0.0 <25",
    "tsup": ">=8.0.0 <9",
    "typescript": ">=5.0.0 <6",
    "vitest": ">=3.0.0 <5"
  }
}

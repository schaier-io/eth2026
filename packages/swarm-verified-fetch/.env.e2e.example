# Copy this file to .env.e2e to run live public Swarm e2e tests.
#
# These fixtures are deterministic public testnet data published through the
# Swarm testnet gateway. They exercise raw immutable bytes, a multi-chunk byte
# tree, a verified Mantaray manifest path, SOC/feed mutable reads, MITM
# rejection, and registry-shaped public reads.

SWARM_PUBLIC_E2E_FIXTURE=test/fixtures/public-gateway.example.json
SWARM_E2E_REGISTRY_FIXTURE=test/fixtures/live-registry.testnet.example.json
SWARM_E2E_GATEWAY_URL=https://api.gateway.testnet.ethswarm.org
SWARM_E2E_BEE_API_URL=https://api.gateway.testnet.ethswarm.org
SWARM_E2E_POSTAGE_MODE=none

# Optional local Bee publishing tests. Set these only when you have a local Bee
# with a usable postage batch. When SWARM_E2E_POSTAGE_MODE=none, upload tests
# omit the postage header for gateways that explicitly allow postageless test
# uploads.
# SWARM_E2E_BEE_API_URL=http://localhost:1633
# SWARM_KV_BEE_API_URL=http://localhost:1633
# SWARM_POSTAGE_BATCH_ID=

# Set to 0 to silence extra e2e progress output.
SWARM_E2E_OUTPUT=1

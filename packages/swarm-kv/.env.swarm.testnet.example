BEE_PASSWORD=replace-with-a-long-local-password
BEE_SEPOLIA_RPC_ENDPOINT=https://ethereum-sepolia-rpc.publicnode.com
BEE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Local Bee testnet mode. Set these when you want e2e tests to exercise your
# own Bee node and postage batch. Leave them unset to let `pnpm test:e2e` use
# Swarm's public testnet upload gateway:
# https://api.gateway.testnet.ethswarm.org
SWARM_KV_BEE_API_URL=http://localhost:1633
SWARM_KV_GATEWAY_URL=http://localhost:1633
SWARM_POSTAGE_BATCH_ID=
